# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://reservation_user:reservation_pass@localhost:5432/reservation_db"
DATABASE_REPLICA_URL="postgresql://reservation_user:reservation_pass@localhost:5433/reservation_db"

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_TTL=3600

# ============================================
# RABBITMQ CONFIGURATION
# ============================================
RABBITMQ_URL=amqp://rabbit_user:rabbit_pass@localhost:5672
RABBITMQ_QUEUE_PREFIX=reservation

# ============================================
# ELASTICSEARCH CONFIGURATION
# ============================================
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=reservation

# ============================================
# S3/MINIO CONFIGURATION
# ============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_user
S3_SECRET_KEY=minio_pass123
S3_BUCKET=reservation-uploads
S3_REGION=us-east-1

# ============================================
# EMAIL CONFIGURATION (Development - Mailhog)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@reservation-system.com

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============================================
# OAUTH PROVIDERS
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# ============================================
# PAYMENT PROVIDERS
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ============================================
# CLOUDINARY (Image Upload - Alternative to MinIO)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# THIRD-PARTY SERVICES
# ============================================
# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email - Production)
SENDGRID_API_KEY=your-sendgrid-api-key

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
API_VERSION=1.0.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=debug
SENTRY_DSN=your-sentry-dsn

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_SWAGGER=true
ENABLE_GRAPHQL=false
ENABLE_WEBSOCKETS=true
ENABLE_CACHING=true

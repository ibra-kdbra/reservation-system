# ============================================
# DATABASE CONFIGURATION (FREE - PostgreSQL)
# ============================================
DATABASE_URL="postgresql://reservation_user:reservation_pass@localhost:5432/reservation_db"
DATABASE_REPLICA_URL="postgresql://reservation_user:reservation_pass@localhost:5433/reservation_db"

# ============================================
# REDIS CONFIGURATION (FREE - Open Source)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_TTL=3600

# ============================================
# RABBITMQ CONFIGURATION (FREE - Open Source)
# ============================================
RABBITMQ_URL=amqp://rabbit_user:rabbit_pass@localhost:5672
RABBITMQ_QUEUE_PREFIX=reservation

# ============================================
# SEARCH ENGINE (FREE - Meilisearch/Elasticsearch)
# ============================================
# Option 1: Meilisearch (Recommended - Lighter)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-master-key

# Option 2: Elasticsearch (More powerful)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=reservation

# ============================================
# FILE STORAGE (FREE - MinIO Self-Hosted S3)
# ============================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio_user
MINIO_SECRET_KEY=minio_pass123
MINIO_BUCKET=reservation-uploads
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# Alternative: Cloudflare R2 (Free Tier - 10GB)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY=your-access-key
# R2_SECRET_KEY=your-secret-key
# R2_BUCKET=reservation-uploads

# ============================================
# EMAIL CONFIGURATION (FREE OPTIONS)
# ============================================
# Option 1: Resend (Free Tier - 3,000 emails/month)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@yourdomain.com

# Option 2: Brevo/Sendinblue (Free Tier - 300 emails/day)
# BREVO_API_KEY=your-api-key
# EMAIL_FROM=noreply@yourdomain.com

# Option 3: Self-Hosted Postal
# POSTAL_HOST=http://localhost:5000
# POSTAL_API_KEY=your-api-key
# EMAIL_FROM=noreply@yourdomain.com

# Development: Mailhog (Already in docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@reservation-system.local

# ============================================
# SMS CONFIGURATION (OPTIONAL - NOT RECOMMENDED)
# ============================================
# Recommendation: Skip SMS, use email verification only
# SMS_ENABLED=false

# If you really need SMS:
# VONAGE_API_KEY=your-api-key
# VONAGE_API_SECRET=your-api-secret
# VONAGE_FROM_NUMBER=+1234567890

# ============================================
# AUTHENTICATION & SECURITY (FREE)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============================================
# OAUTH PROVIDERS (FREE)
# ============================================
# Google OAuth (Free)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# GitHub OAuth (Free)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# ============================================
# PAYMENT PROVIDERS (PAY-PER-TRANSACTION)
# ============================================
# Stripe (No monthly fee, 2.9% + $0.30 per transaction)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal (Similar pricing to Stripe)
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_MODE=sandbox

# ============================================
# IMAGE PROCESSING (FREE - Sharp)
# ============================================
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=80
IMAGE_FORMAT=webp

# ============================================
# MAPS (FREE - OpenStreetMap + Leaflet)
# ============================================
# No API key needed for OpenStreetMap!
MAP_PROVIDER=openstreetmap
MAP_DEFAULT_ZOOM=13

# Alternative: Mapbox (Free Tier - 50,000 loads/month)
# MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ============================================
# CDN (FREE - Cloudflare)
# ============================================
# Cloudflare Free Tier - Unlimited bandwidth
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-api-token

# ============================================
# ERROR TRACKING (FREE - Self-Hosted Sentry)
# ============================================
SENTRY_DSN=http://your-sentry-instance/project-id
SENTRY_ENVIRONMENT=development

# Alternative: GlitchTip (Sentry-compatible, simpler)
# GLITCHTIP_DSN=http://your-glitchtip-instance/project-id

# ============================================
# ANALYTICS (FREE - Self-Hosted)
# ============================================
# Option 1: Umami (Recommended - Simple)
UMAMI_WEBSITE_ID=your-website-id
UMAMI_API_URL=http://localhost:3001

# Option 2: Matomo (More features)
# MATOMO_SITE_ID=1
# MATOMO_URL=http://localhost:8080

# Option 3: Plausible (Privacy-focused)
# PLAUSIBLE_DOMAIN=yourdomain.com
# PLAUSIBLE_API_URL=http://localhost:8000

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
API_VERSION=1.0.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# RATE LIMITING (FREE - Built-in)
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10

# ============================================
# MONITORING & LOGGING (FREE - Open Source)
# ============================================
LOG_LEVEL=debug

# Prometheus (Already in docker-compose)
PROMETHEUS_PORT=9090

# Grafana (Already in docker-compose)
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Loki (Log aggregation - alternative to ELK)
LOKI_URL=http://localhost:3100

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_SWAGGER=true
ENABLE_GRAPHQL=false
ENABLE_WEBSOCKETS=true
ENABLE_CACHING=true
ENABLE_SMS=false

# ============================================
# HOSTING (FREE OPTIONS)
# ============================================
# Option 1: Oracle Cloud Always Free
# - 4 Arm VMs (24GB RAM total)
# - 200GB storage
# - Permanent free tier

# Option 2: Google Cloud Free Tier
# - 1 f1-micro instance
# - 30GB storage
# - Permanent free tier

# Option 3: Self-Hosted VPS
# - Hetzner: $5/month (4GB RAM)
# - DigitalOcean: $6/month (1GB RAM)
# - Vultr: $6/month (1GB RAM)

# ============================================
# SSL CERTIFICATES (FREE - Let's Encrypt)
# ============================================
# Automatic with Certbot or Traefik
SSL_EMAIL=admin@yourdomain.com

# ============================================
# BACKUP (FREE - Restic + Backblaze B2)
# ============================================
# Backblaze B2 (10GB free)
B2_APPLICATION_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key
B2_BUCKET=reservation-backups

# Alternative: Local backups
BACKUP_PATH=/var/backups/reservation-system
BACKUP_RETENTION_DAYS=30

# ============================================
# UPTIME MONITORING (FREE)
# ============================================
# Option 1: Self-Hosted Uptime Kuma
UPTIME_KUMA_URL=http://localhost:3002

# Option 2: UptimeRobot (Free Tier - 50 monitors)
# UPTIMEROBOT_API_KEY=your-api-key

# ============================================
# CI/CD (FREE - GitHub Actions)
# ============================================
# GitHub Actions: 2,000 minutes/month for private repos
# Unlimited for public repos
# No configuration needed here

# ============================================
# CONTAINER REGISTRY (FREE)
# ============================================
# GitHub Container Registry (GHCR)
# - Unlimited public images
# - 500MB free for private
GHCR_TOKEN=your-github-token

# Alternative: Docker Hub (1 private repo free)
# DOCKER_USERNAME=your-username
# DOCKER_PASSWORD=your-password
